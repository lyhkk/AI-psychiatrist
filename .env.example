# CBT-MAS

# base llm
LLM_API_KEY=sk-
LLM_BASE_URL=https://api.siliconflow.cn/v1

# Front model (System 1)
THERAPIST_API_KEY=sk-
THERAPIST_BASE_URL=https://api.siliconflow.cn/v1
THERAPIST_MODEL=Pro/zai-org/GLM-5

# Back model (System 2)
SUPERVISOR_API_KEY=sk-
SUPERVISOR_BASE_URL=https://api.siliconflow.cn/v1
SUPERVISOR_MODEL=Pro/zai-org/GLM-5

# Judge model
JUDGE_API_KEY=sk-
JUDGE_BASE_URL=https://api.siliconflow.cn/v1
JUDGE_MODEL=deepseek-ai/DeepSeek-V3.2

# 用于 baseline 评测
BASELINE_API_KEY=sk-
BASELINE_BASE_URL=https://api.siliconflow.cn/v1
BASELINE_MODEL=deepseek-ai/DeepSeek-V3.2

# setting
DEBUG=true
MAX_TURNS_PER_STAGE=15

# 测试阶段关闭危机检测，避免评测语料中的危机关键词打断 CBT 流程
ENABLE_CRISIS_DETECTION=false

# 正式上线时恢复
# ENABLE_CRISIS_DETECTION=true

# 会话本地持久化（webapp）：每轮对话后将对话历史 + CBT 诊断表原子写入磁盘
# 服务重启后，未关闭的浏览器标签可凭 cookie 自动续聊
ENABLE_SESSION_PERSISTENCE=true
SESSION_STORE_DIR=results/sessions